  "commandes_curl": {
    "autorisation_simple": "curl -s -X POST http://localhost:5000/api/v1/authorize -H 'Content-Type: application/json' -d '{\"pan\":\"4111111111111111\",\"amount\":4500,\"currency\":\"978\",\"transaction_type\":\"00\",\"terminal_id\":\"TERM0001\",\"merchant_id\":\"MERCH001\",\"pos_entry_mode\":\"010\"}'",
    "stats": "curl -s http://localhost:5000/api/v1/stats | python -m json.tool",
    "liste_transactions": "curl -s http://localhost:5000/api/v1/transactions | python -m json.tool",
    "token_create": "curl -s -X POST http://localhost:5000/api/v1/tokens -H 'Content-Type: application/json' -d '{\"pan\":\"4111111111111111\",\"domain\":\"HCE_MOBILE\"}'",
    "3ds_auth": "curl -s -X POST http://localhost:5000/api/v1/3ds/authenticate -H 'Content-Type: application/json' -d '{\"pan\":\"4111111111111111\",\"amount\":20000,\"currency\":\"978\",\"merchant_id\":\"SHOP001\"}'",
    "chaos_enable": "curl -s -X POST http://localhost:5000/api/v1/chaos/enable -H 'Content-Type: application/json' -d '{\"failure_rate\":0.5,\"failure_types\":[\"TIMEOUT\"]}'",
    "chaos_disable": "curl -s -X POST http://localhost:5000/api/v1/chaos/disable",
    "config_reload": "curl -s -X POST http://localhost:5000/api/v1/config/reload",
    "hsm_status": "curl -s http://localhost:5000/api/v1/hsm/status | python -m json.tool",
    "cache_stats": "curl -s http://localhost:5000/api/v1/cache/stats | python -m json.tool"
  }
